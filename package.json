{
  "name": "spark",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "pnpm db:generate && next build",
    "start": "next start",
    "test": "vitest run",
    "test:e2e": "start-server-and-test \"pnpm db:push && pnpm db:seed && pnpm next dev --hostname 127.0.0.1 --port 3000\" http://127.0.0.1:3000 \"playwright test --config=playwright.config.ts\"",
    "typecheck": "pnpm db:generate && next typegen && node -e \"const fs=require('fs');fs.mkdirSync('.next/types',{recursive:true});const path='.next/types/cache-life.d.ts';if(!fs.existsSync(path))fs.writeFileSync(path,'export {};\\n');\" && tsc --noEmit",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@ai-sdk/openai": "3.0.41",
    "@prisma/client": "6.5.0",
    "@resvg/resvg-js": "^2.6.2",
    "@resvg/resvg-js-darwin-arm64": "2.6.2",
    "ai": "6.0.116",
    "next": "16.1.6",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "sharp": "^0.34.5",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.2.0",
    "@types/node": "22.13.14",
    "@types/react": "19.0.12",
    "@types/react-dom": "19.0.5",
    "@types/sharp": "^0.32.0",
    "@vitejs/plugin-react": "4.3.4",
    "autoprefixer": "10.4.20",
    "jsdom": "26.0.0",
    "postcss": "8.5.3",
    "prisma": "6.5.0",
    "start-server-and-test": "^2.1.5",
    "tailwindcss": "3.4.17",
    "tsx": "4.19.3",
    "typescript": "5.8.2",
    "vitest": "3.0.8"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
